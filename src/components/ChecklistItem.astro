---
interface Props {
  kind: "yes" | "no";
  finale?: boolean;
  class?: string;
}

const { kind, finale = false, class: className } = Astro.props;
---

<li
  class:list={[
    "flex gap-3",
    finale ? "items-center" : "",
    kind === "no" && !finale && "text-dark-muted",
    className,
  ]}
>
  <span
    class:list={[
      kind === "yes" ? "text-accent" : "text-dark-muted",
      "font-bold",
    ]}
    aria-hidden="true">{kind === "yes" ? "✓" : "×"}</span
  ><slot />
</li>
