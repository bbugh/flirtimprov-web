---
interface Props {
  label: string;
  divider?: boolean;
}

const { label, divider = false } = Astro.props;
---

<div class:list={["text-center", divider && "border-divider sm:border-r"]}>
  <p class="font-display text-5xl font-medium text-accent">
    <slot />
  </p>
  <p
    class="mt-3 text-xs font-semibold tracking-widest text-dark-muted uppercase"
  >
    {label}
  </p>
</div>
