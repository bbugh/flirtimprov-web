---
import { Image } from "astro:assets";

interface Props {
  src: ImageMetadata;
  alt: string;
  caption: string;
  imgClass?: string;
  class?: string;
  loading?: "eager" | "lazy";
  fetchpriority?: "high" | "low" | "auto";
  widths?: number[];
  sizes?: string;
}

const {
  src,
  alt,
  caption,
  imgClass,
  class: className,
  loading = "lazy",
  fetchpriority = "auto",
  widths = [768, 1280, 1920],
  sizes = "100vw",
} = Astro.props;
---

<figure class={className}>
  <div class="relative overflow-hidden">
    <Image
      src={src}
      alt={alt}
      class:list={["w-full object-cover", imgClass]}
      widths={widths}
      sizes={sizes}
      loading={loading}
      fetchpriority={fetchpriority}
    />
    <div
      class="pointer-events-none absolute inset-x-0 bottom-0 h-1/3 bg-linear-to-t from-dark-recessed/85 to-transparent"
    >
    </div>
    <figcaption
      class="absolute inset-x-0 bottom-0 px-4 py-3 text-center font-semibold tracking-wider text-light/80 uppercase drop-shadow-sm sm:px-5"
    >
      {caption}
    </figcaption>
  </div>
</figure>
