---
import Card from "@/components/Card.astro";

interface Props {
  name: string;
  role: string;
  initial: string;
}

const { name, role, initial } = Astro.props;
---

<Card variant="quote" as="figure" class="flex flex-col">
  <span aria-hidden="true" class="mb-2 font-display text-5xl text-accent"
    >&ldquo;</span
  >
  <blockquote class="mb-6 font-display text-xl italic">
    <slot />
  </blockquote>
  <figcaption class="mt-auto flex items-center gap-3">
    <span
      class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-accent font-display text-lg text-light"
      >{initial}</span
    >
    <span>
      <span class="block font-semibold">{name}</span>
      <span class="block text-sm text-dark-muted">{role}</span>
    </span>
  </figcaption>
</Card>
