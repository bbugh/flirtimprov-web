---
import Container from "@/components/Container.astro";
---

<Container class="max-w-3xl text-center">
  <figure>
    <p aria-hidden="true" class="mb-2 font-display text-6xl text-accent">
      &ldquo;
    </p>
    <blockquote class="mb-6 font-display text-3xl italic sm:text-4xl">
      I came in nervous and left with a cramp from laughing. Easily the best
      Tuesday I've had in years.
    </blockquote>
    <figcaption
      class="text-sm font-semibold tracking-widest text-accent uppercase"
    >
      Priya R. &middot; First-timer
    </figcaption>
  </figure>
</Container>
