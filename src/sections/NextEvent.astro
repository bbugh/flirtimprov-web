---
import Container from "@/components/Container.astro";
import Card from "@/components/Card.astro";
import Button from "@/components/Button.astro";
---

<Container class="w-full max-w-3xl">
  <Card
    variant="event"
    class="flex flex-col items-start justify-between gap-6 sm:flex-row sm:items-center"
  >
    <div>
      <p
        class="mb-2 text-xs font-semibold tracking-widest text-accent uppercase"
      >
        The next event
      </p>
      <p class="mb-1 font-display text-3xl font-semibold">To be announced</p>
      <p>San Diego &middot; dates released to the list first</p>
    </div>
    <Button href="#join" class="shrink-0">Notify me</Button>
  </Card>
</Container>
