---
import Container from "@/components/Container.astro";
import Button from "@/components/Button.astro";
---

<Container id="join" class="max-w-2xl text-center">
  <h2 class="mb-4 text-light">Ready to discover your flirting superpowers?</h2>
  <p class="mb-5 font-display text-2xl text-accent italic">
    Flirt Improv is coming to you, San Diego!
  </p>
  <p class="mx-auto mb-10 max-w-md text-lg text-light-muted">
    Complete our interest form below to get event updates!
  </p>

  <form action="#" method="post" class="grid gap-4 text-left sm:grid-cols-2">
    <div>
      <label
        for="name"
        class="mb-1.5 block text-sm font-medium text-light-muted">Name</label
      >
      <input
        id="name"
        name="name"
        type="text"
        autocomplete="name"
        placeholder="Your name"
        class="w-full rounded-xs bg-light px-4 py-3 text-dark outline-hidden placeholder:text-dark-muted focus:ring-2 focus:ring-accent"
      />
    </div>
    <div>
      <label
        for="email"
        class="mb-1.5 block text-sm font-medium text-light-muted">Email</label
      >
      <input
        id="email"
        name="email"
        type="email"
        autocomplete="email"
        placeholder="you@example.com"
        required
        class="w-full rounded-xs bg-light px-4 py-3 text-dark outline-hidden placeholder:text-dark-muted focus:ring-2 focus:ring-accent"
      />
    </div>
    <div class="sm:col-span-2">
      <label
        for="city"
        class="mb-1.5 block text-sm font-medium text-light-muted"
        >Which city are you in?</label
      >
      <input
        id="city"
        name="city"
        type="text"
        placeholder="City"
        class="w-full rounded-xs bg-light px-4 py-3 text-dark outline-hidden placeholder:text-dark-muted focus:ring-2 focus:ring-accent"
      />
    </div>
    <div
      class="mt-2 flex flex-col items-center gap-4 sm:col-span-2 sm:flex-row"
    >
      <Button type="submit" on="dark" size="lg" class="w-full sm:w-auto"
        >Send me event updates</Button
      >
      <p class="text-sm text-light-muted">
        We'll only email you about upcoming events.
      </p>
    </div>
  </form>
</Container>
